  --red: #b91c1c;
  --gold: #D4AF37;
  --dark: #1a0000;
  --bg-light: #fff5f5;
}
* { margin:0; padding:0; box-sizing:border-box; }
body { font-family:'Segoe UI',sans-serif; scroll-behavior:smooth; }

/* NAVBAR */
.navbar {
  position:fixed; top:0; width:100%;
  background:var(--dark); z-index:1000;
  padding:15px 30px;
  display:flex; justify-content:space-between; align-items:center;
}
.navbar .logo { font-size:1.8rem; font-weight:bold; color:var(--gold); letter-spacing:3px; }
.navbar .logo span { color:white; }
.nav-links { display:flex; list-style:none; gap:25px; }
.nav-links a { color:white; text-decoration:none; font-size:0.95rem; transition:0.3s; }
.nav-links a:hover { color:var(--gold); }

/* HERO */
.hero {
  min-height:100vh;
  background:linear-gradient(rgba(139,0,0,0.75),rgba(26,0,0,0.92)),
    url('https://images.unsplash.com/photo-1585937421612-70a008356fbe?w=1600') center/cover no-repeat;
  display:flex; flex-direction:column;
  align-items:center; justify-content:center;
  text-align:center; padding:100px 20px 40px; color:white;
}
.hero .logo-text {
  font-size:4rem; font-weight:bold;
  color:var(--gold); letter-spacing:6px;
  text-shadow:2px 2px 20px rgba(0,0,0,0.6);
}
.hero .tagline { font-size:1.2rem; margin:15px 0 30px; color:#ffdddd; }
.btn-primary {
  background:var(--deep-red); color:white;
  padding:15px 45px; border:2px solid var(--gold);
  border-radius:50px; font-size:1rem;
  cursor:pointer; text-decoration:none; transition:0.3s;
  display:inline-block;
}
.btn-primary:hover { background:var(--gold); color:var(--dark); }

/* ABOUT */
.about { background:var(--bg-light); padding:80px 40px; text-align:center; }
.section-title {
  font-size:2.2rem; color:var(--deep-red);
  margin-bottom:15px; font-weight:bold;
}
.section-title::after {
  content:''; display:block; width:80px; height:4px;
  background:var(--gold); margin:10px auto 0; border-radius:2px;
}
.about p {
  max-width:720px; margin:20px auto;
  font-size:1.05rem; color:#555; line-height:1.9;
}

/* DISCOUNT BANNER */
.discount-banner {
  background:linear-gradient(135deg,var(--deep-red),#4a0000);
  color:white; text-align:center;
  padding:22px; font-size:1.2rem; font-weight:bold;
  animation:pulse 2s infinite;
}
@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.85} }

/* MENU SECTION */
.menu-section { padding:80px 20px; background:white; }
.menu-tabs {
  display:flex; flex-wrap:wrap; gap:10px;
  justify-content:center; margin-bottom:40px;
}
.menu-tab {
  padding:10px 20px;
  background:var(--bg-light);
  border:2px solid var(--deep-red);
  color:var(--deep-red); border-radius:25px;
  cursor:pointer; font-weight:600; transition:0.3s;
  font-size:0.9rem;
}
.menu-tab.active, .menu-tab:hover { background:var(--deep-red); color:white; }
.menu-content { display:none; max-width:1200px; margin:0 auto; }
.menu-content.active { display:block; }
.menu-subcategory { margin-bottom:30px; }
.menu-subcategory h3 {
  color:var(--gold); background:var(--dark);
  padding:10px 20px; border-radius:8px;
  font-size:1rem; margin-bottom:15px; letter-spacing:1px;
}
.menu-grid {
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(240px,1fr));
  gap:10px;
}
.menu-item {
  background:var(--bg-light);
  border-left:4px solid var(--deep-red);
  padding:12px 15px; border-radius:8px;
  display:flex; justify-content:space-between;
  align-items:center; transition:0.3s;
}
.menu-item:hover { background:#ffe4e4; transform:translateX(5px); }
.item-name { font-weight:500; color:var(--dark); font-size:0.88rem; }
.item-price { font-weight:bold; color:var(--deep-red); font-size:0.92rem; white-space:nowrap; margin-left:8px; }

/* REVIEWS */
.reviews-section { background:var(--bg-light); padding:70px 20px; }
.reviews-grid {
  max-width:1000px; margin:30px auto 0;
  display:grid; grid-template-columns:repeat(auto-fit,minmax(280px,1fr)); gap:20px;
}
.review-card {
  background:white; border-radius:12px;
  padding:22px; box-shadow:0 4px 15px rgba(139,0,0,0.1);
  border-top:4px solid var(--deep-red);
}
.review-card .stars { color:var(--gold); font-size:1.1rem; }
.review-card p { color:#555; margin:10px 0; font-style:italic; line-height:1.7; }
.review-card .reviewer { font-weight:bold; color:var(--deep-red); }

/* CONTACT PAGE 4 */
.contact-section { background:var(--dark); padding:80px 20px; }
.contact-grid {
  max-width:1200px; margin:30px auto 0;
  display:grid; grid-template-columns:repeat(auto-fit,minmax(240px,1fr)); gap:25px;
}
.contact-card {
  background:rgba(255,255,255,0.05);
  border:1px solid rgba(212,175,55,0.3);
  border-radius:12px; padding:28px; text-align:center; transition:0.3s;
}
.contact-card:hover { border-color:var(--gold); transform:translateY(-5px); }
.contact-card .icon { font-size:2.5rem; margin-bottom:12px; }
.contact-card h3 { color:var(--gold); margin-bottom:10px; font-size:1rem; }
.contact-card a {
  color:white; text-decoration:none;
  font-size:0.92rem; transition:0.3s;
}
.contact-card a:hover { color:var(--gold); }

/* WHATSAPP FLOAT */
.whatsapp-float {
  position:fixed; bottom:30px; right:30px;
  background:#25D366; color:white;
  width:62px; height:62px; border-radius:50%;
  display:flex; align-items:center; justify-content:center;
  font-size:1.8rem; text-decoration:none; z-index:9999;
  box-shadow:0 4px 20px rgba(37,211,102,0.5);
  animation:bounce 2s infinite;
}
@keyframes bounce { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-8px)} }

/* FOOTER */
.footer {
